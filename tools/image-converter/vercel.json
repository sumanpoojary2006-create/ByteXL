{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "services": {
    "bytexl-image-converter": {
      "root": ".",
      "entrypoint": "server:app"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "bytexl-image-converter"
      }
    }
  ]
}
